# CaseCommand — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git

# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SECRET_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# === App ===
BASE_URL=https://casecommand.onrender.com
AUTH_TOKEN=your-legacy-bearer-token
DEBUG=false

# === Stripe Billing (required for SaaS) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_FIRM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# === Telegram (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# === Twilio (optional) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TWILIO_ALLOWED_NUMBERS=

# === Rate Limiting (optional overrides) ===
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_AI=20/minute
