# CaseCommand Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git

# Anthropic API Key (get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ACTUAL_KEY

# Supabase Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Publishable Key (client-side, starts with sb_publishable_)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE

# Supabase Secret Key (server-side, starts with sb_secret_)
# Get from: Supabase Dashboard → Settings → API Keys
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY_HERE

# Public URL of your deployment (needed for webhook registration)
# Example: https://casecommand.onrender.com
BASE_URL=

# --- Telegram Integration (optional) ---
# Create a bot via @BotFather on Telegram, get the token
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
TELEGRAM_ALLOWED_USERS=

# --- Twilio SMS/WhatsApp Integration (optional) ---
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number for SMS (e.g., +15551234567)
TWILIO_PHONE_NUMBER=
# Your Twilio WhatsApp number (e.g., whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=
# Comma-separated phone numbers allowed to message (empty = allow all)
TWILIO_ALLOWED_NUMBERS=
