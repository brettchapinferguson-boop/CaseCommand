# CaseCommand Configuration
# Copy this file: cp .env.example .env
# Then edit .env with your values

# Required: Your Anthropic API key
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Claude model (default: claude-sonnet-4-5-20250514)
# CLAUDE_MODEL=claude-sonnet-4-5-20250514

# Optional: Server port (default: 3000)
# PORT=3000

# Optional: Log level (default: INFO)
# LOG_LEVEL=INFO

# Optional: CORS allowed origins (comma-separated, default: *)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional: Session management
# SESSION_TTL_SECONDS=3600
# SESSION_CLEANUP_INTERVAL=300
# MAX_SESSIONS=1000

# Optional: Rate limiting (per IP, AI endpoints only)
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW=60

# Optional: Input size limits (characters)
# MAX_MESSAGE_LENGTH=50000
# MAX_SYSTEM_PROMPT_LENGTH=100000
